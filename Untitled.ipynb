    "        \"id\": \"gU8klDoaRpH0\",\n",
    "        \"outputId\": \"42aeac6a-b3b3-4da1-a3bd-162d0d052c65\"\n",
    "      },\n",
    "      \"outputs\": [\n",
    "        {\n",
    "          \"data\": {\n",
    "            \"image/png\": \"\n",
    "\n",
    "\",\n",
