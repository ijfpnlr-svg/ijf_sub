    "              \"<Figure size 640x480 with 2 Axes>\"\n",
    "            ]\n",
    "          },\n",
    "          \"metadata\": {},\n",
    "          \"output_type\": \"display_data\"\n",
    "        }\n",
    "      ],\n",
    "      \"source\": [\n",
    "        \"fig, ax = plt.subplots(2, 1)\\n\",\n",
    "        \"plot_maze(ax[0], [idx_to_state[code] for code in state_traj], \\\"True\\\", \\\"red\\\")\\n\",\n",
    "        \"plot_maze(ax[1], [idx_to_state[code] for code in state_traj_viterbi], \\\"Viterbi\\\", \\\"black\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {\n",
    "        \"id\": \"BQGKw-DQUsuU\"\n",
    "      },\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"## BONUS: Forward algorithm (for state prediction, slightly different from the one presented in the course)\\n\",\n",
    "        \"\\n\",\n",
    "        \"alpha_all = np.zeros((T, N))\\n\",\n",
    "        \"alpha_pred = pi\\n\",\n",
    "        \"for idx in range(T):\\n\",\n",
    "        \"    alpha_upd = alpha_pred * B[:, obs_traj[idx]]  # Update step\\n\",\n",
    "        \"    alpha_upd = alpha_upd / np.sum(alpha_upd)  # Normalize\\n\",\n",
    "        \"    alpha_all[idx, :] = alpha_upd\\n\",\n",
    "        \"    alpha_pred = A.T @ alpha_upd  # Predict step\"\n",
    "      ]\n",
    "    },\n",
