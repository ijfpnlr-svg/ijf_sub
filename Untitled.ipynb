    "      \"source\": [\n",
    "        \"fig, ax = plt.subplots()\\n\",\n",
    "        \"plot_maze(ax, [idx_to_state[code] for code in state_traj], \\\"T\\\", \\\"red\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1272,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"## Viterbi algorithm\\n\",\n",
    "        \"\\n\",\n",
    "        \"T = len(obs_traj)\\n\",\n",
    "        \"\\n\",\n",
    "        \"delta = np.empty((T, N))\\n\",\n",
    "        \"psi = np.empty((T, N), dtype=int)\\n\",\n",
    "        \"\\n\",\n",
    "        \"delta[0] = pi * B[:, obs_traj[0]]\\n\",\n",
    "        \"for t in range(1, T):\\n\",\n",
    "        \"    for j in range(N):\\n\",\n",
    "        \"        prob = delta[t - 1] * A[:, j]\\n\",\n",
    "        \"        psi[t, j] = np.argmax(prob)\\n\",\n",
    "        \"        delta[t, j] = np.max(prob) * B[j, obs_traj[t]]\\n\",\n",
    "        \"\\n\",\n",
    "        \"# Backtrack\\n\",\n",
    "        \"path = np.zeros(T, dtype=int)\\n\",\n",
    "        \"path[T - 1] = np.argmax(delta[T - 1])\\n\",\n",
    "        \"for t in range(T - 2, -1, -1):\\n\",\n",
    "        \"    path[t] = psi[t + 1, path[t + 1]] \\n\",\n",
    "        \"\\n\",\n",
    "        \"state_traj_viterbi = np.array(path)\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
