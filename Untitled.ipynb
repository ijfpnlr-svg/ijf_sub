    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1260,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"obs_to_idx = {obs: i for i, obs in enumerate(vocabulary)}\\n\",\n",
    "        \"idx_to_obs = {i: obs for i, obs in enumerate(vocabulary)}\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1261,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"## Step 2: Build uniform transition probability matrix\\n\",\n",
    "        \"def build_emission_matrix(states, noise=0.0):\\n\",\n",
    "        \"    V = 16\\n\",\n",
    "        \"    N = len(states)\\n\",\n",
    "        \"    B = np.zeros((N, V))\\n\",\n",
    "        \"    for i, (r, c) in enumerate(states):\\n\",\n",
    "        \"        idx_meas = 0\\n\",\n",
    "        \"        if (r-1, c) in states: # NORTH allowed?\\n\",\n",
    "        \"            idx_meas += 2**3\\n\",\n",
    "        \"        if (r+1, c) in states: # SOUTH allowed?\\n\",\n",
    "        \"            idx_meas += 2**2\\n\",\n",
    "        \"        if (r, c-1) in states: # WEST allowed?\\n\",\n",
    "        \"            idx_meas += 2**1\\n\",\n",
    "        \"        if (r, c+1) in states: # EAST allowed?\\n\",\n",
    "        \"            idx_meas += 2**0\\n\",\n",
    "        \"        B[i, :] = noise / (V-1)\\n\",\n",
    "        \"        B[i, idx_meas] = 1.0 - noise\\n\",\n",
    "        \"    return B\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1262,\n",
    "      \"metadata\": {},\n",
