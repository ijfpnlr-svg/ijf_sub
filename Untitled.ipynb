    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"pi = np.ones(N) / N\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1265,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"def simulate_HMM(A, B, pi, T): # TODO handle an explicit seed?\\n\",\n",
    "        \"    N = A.shape[0]\\n\",\n",
    "        \"    V = B.shape[1]\\n\",\n",
    "        \"    observations = np.empty(T, dtype=int) # sequence of observations\\n\",\n",
    "        \"    states = np.empty(T, dtype=int) # sequence of states\\n\",\n",
    "        \"    # assert() # TODO SANITY CHECKS ON DIMENSIONS MAYBE\\n\",\n",
    "        \"    q_step = np.random.choice(range(N), p=pi)\\n\",\n",
    "        \"    for t in range(T):\\n\",\n",
    "        \"        states[t] = q_step # save current state\\n\",\n",
    "        \"        observations[t] = np.random.choice(range(V), p=B[q_step]) # save current emission\\n\",\n",
    "        \"        q_step = np.random.choice(range(N), p=A[q_step]) # \\n\",\n",
    "        \"    return observations, states\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1266,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"def simulate_HMM_no_rep(A, B, pi, T): # TODO handle an explicit seed?\\n\",\n",
    "        \"    N = A.shape[0]\\n\",\n",
    "        \"    V = B.shape[1]\\n\",\n",
    "        \"    observations = np.empty(T, dtype=int) # sequence of observations\\n\",\n",
    "        \"    states = np.empty(T, dtype=int) # sequence of states\\n\",\n",
    "        \"    # assert() # TODO SANITY CHECKS ON DIMENSIONS MAYBE\\n\",\n",
    "        \"    q_step = np.random.choice(range(N), p=pi)\\n\",\n",
    "        \"    for t in range(T):\\n\",\n",
    "        \"        states[t] = q_step # save current state\\n\",\n",
    "        \"        observations[t] = np.random.choice(range(V), p=B[q_step]) # save current emission\\n\",\n",
    "        \"        prob_step = np.copy(A[q_step])\\n\",\n",
    "        \"        idx_visited = np.unique(states[:t+1])\\n\",\n",
    "        \"        prob_step[idx_visited] = 0\\n\",\n",
    "        \"        if np.sum(prob_step) == 0:\\n\",\n",
    "        \"            observations = observations[:t+1]  # truncate observations\\n\",\n",
    "        \"            states = states[:t+1]  # truncate states\\n\",\n",
    "        \"            break\\n\",\n",
    "        \"        else:\\n\",\n",
    "        \"            prob_step = prob_step/np.sum(prob_step)\\n\",\n",
    "        \"        q_step = np.random.choice(range(N), p=prob_step) # \\n\",\n",
    "        \"    return observations, states\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1267,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"# To handle emissions only\\n\",\n",
    "        \"def simulate_emissions(B, states): # TODO handle an explicit seed?\\n\",\n",
    "        \"    V = B.shape[1]\\n\",\n",
    "        \"    observations = []\\n\",\n",
    "        \"    for q_step in states:\\n\",\n",
    "        \"        observations.append(np.random.choice(range(V), p=B[q_step])) # save current emission\\n\",\n",
    "        \"    return observations\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": 1268,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"# Option 1: generate from HMM\\n\",\n",
    "        \"obs_traj, state_traj = simulate_HMM(A, B, pi, 20)\"\n",
